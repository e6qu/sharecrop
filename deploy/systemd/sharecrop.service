[Unit]
Description=Sharecrop web and MCP service
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=sharecrop
Group=sharecrop
WorkingDirectory=/opt/sharecrop
EnvironmentFile=/etc/sharecrop/sharecrop.env
ExecStart=/opt/sharecrop/bin/sharecrop serve
Restart=on-failure
RestartSec=5s
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/sharecrop

[Install]
WantedBy=multi-user.target
