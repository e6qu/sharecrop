{
  "family": "sharecrop-serve",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT:role/REPLACE_execution_role",
  "taskRoleArn": "arn:aws:iam::REPLACE_ACCOUNT:role/REPLACE_task_role",
  "containerDefinitions": [
    {
      "name": "sharecrop",
      "image": "REPLACE_REGISTRY/sharecrop:REPLACE_TAG",
      "essential": true,
      "command": ["serve"],
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "SHARECROP_HTTP_ADDR", "value": ":8080" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT:secret:sharecrop/database-url" },
        { "name": "SHARECROP_ACCESS_TOKEN_SECRET", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT:secret:sharecrop/access-token-secret" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sharecrop-serve",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "sharecrop"
        }
      }
    }
  ]
}
