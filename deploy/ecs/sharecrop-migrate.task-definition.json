{
  "family": "sharecrop-migrate",
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT:role/REPLACE_execution_role",
  "taskRoleArn": "arn:aws:iam::REPLACE_ACCOUNT:role/REPLACE_task_role",
  "containerDefinitions": [
    {
      "name": "sharecrop-migrate",
      "image": "REPLACE_REGISTRY/sharecrop:REPLACE_TAG",
      "essential": true,
      "command": ["migrate", "up"],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:REPLACE_REGION:REPLACE_ACCOUNT:secret:sharecrop/database-url" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/sharecrop-migrate",
          "awslogs-region": "REPLACE_REGION",
          "awslogs-stream-prefix": "sharecrop"
        }
      }
    }
  ]
}
